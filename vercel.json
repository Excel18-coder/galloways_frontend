{
  "version": 2,
  "installCommand": "cd frontend && pnpm install",
  "buildCommand": "cd frontend && pnpm run build",
  "outputDirectory": "frontend/dist",
  "routes": [
    {
      "src": "/sitemap.xml",
      "dest": "/sitemap.xml"
    },
    {
      "src": "/robots.txt", 
      "dest": "/robots.txt"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}